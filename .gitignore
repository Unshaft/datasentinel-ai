# DataSentinel AI - Git Ignore
# ============================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Environments
.env
.env.local
.env.*.local
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# Data files (keep structure, ignore content)
data/chroma/*
!data/chroma/.gitkeep
data/samples/*
!data/samples/.gitkeep
!data/rules/default_rules.json

# Runtime data (stats, webhooks, domain agents — générés à l'exécution)
data/stats.json
data/webhooks.json
data/domain_agents.json
data/feedback_stats.json

# Test data ChromaDB (binaires générés par les tests)
test_data/

# Uploaded files
uploads/

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Secrets
*.pem
*.key
secrets/
credentials/

# Temporary files
tmp/
temp/
*.tmp
*.temp
