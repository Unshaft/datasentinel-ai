# DataSentinel AI - Configuration
# ================================
# Copier ce fichier vers .env et remplir les valeurs

# ===================
# API Keys (REQUIRED)
# ===================

# Anthropic API Key pour Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ===================
# Application Config
# ===================

# Environnement: development, staging, production
ENVIRONMENT=development

# Niveau de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===================
# API Server
# ===================

# Host et port pour FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Workers (production only)
API_WORKERS=1

# ===================
# ChromaDB
# ===================

# Chemin de persistance ChromaDB
CHROMA_PERSIST_PATH=./data/chroma

# Nom des collections
CHROMA_RULES_COLLECTION=business_rules
CHROMA_DECISIONS_COLLECTION=decision_history
CHROMA_FEEDBACK_COLLECTION=user_feedback

# ===================
# Model Configuration
# ===================

# Modèle Claude à utiliser
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Température pour les réponses (0.0 = déterministe, 1.0 = créatif)
CLAUDE_TEMPERATURE=0.1

# Tokens maximum par réponse
CLAUDE_MAX_TOKENS=4096

# ===================
# Agent Configuration
# ===================

# Seuil de confiance pour escalade humaine (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.7

# Nombre maximum d'itérations par agent
MAX_AGENT_ITERATIONS=10

# Timeout par appel agent (secondes)
AGENT_TIMEOUT=60

# ===================
# ML Configuration
# ===================

# Contamination rate pour Isolation Forest (proportion d'anomalies attendues)
ANOMALY_CONTAMINATION=0.1

# Seuil p-value pour détection de drift (KS-test)
DRIFT_PVALUE_THRESHOLD=0.05

# ===================
# Data Limits
# ===================

# Taille maximale de fichier uploadé (bytes)
MAX_UPLOAD_SIZE=104857600

# Nombre maximum de lignes à analyser (0 = illimité)
MAX_ROWS_ANALYZE=100000

# ===================
# Security
# ===================

# CORS origins autorisés (format JSON array requis par pydantic-settings v2)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# API Key pour authentification (optionnel)
# API_SECRET_KEY=your-secret-key-here
