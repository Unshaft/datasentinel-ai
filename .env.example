# DataSentinel AI - Configuration
# ================================
# Copier ce fichier vers .env et remplir les valeurs

# ===================
# API Keys (REQUIRED)
# ===================

# Anthropic API Key pour Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ===================
# Application Config
# ===================

# Environnement: development, staging, production
ENVIRONMENT=development

# Niveau de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===================
# API Server
# ===================

# Host et port pour FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Workers (production only)
API_WORKERS=1

# ===================
# ChromaDB
# ===================

# Chemin de persistance ChromaDB
CHROMA_PERSIST_PATH=./data/chroma

# Nom des collections
CHROMA_RULES_COLLECTION=business_rules
CHROMA_DECISIONS_COLLECTION=decision_history
CHROMA_FEEDBACK_COLLECTION=user_feedback

# ===================
# Model Configuration
# ===================

# Modèle Claude à utiliser
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Température pour les réponses (0.0 = déterministe, 1.0 = créatif)
CLAUDE_TEMPERATURE=0.1

# Tokens maximum par réponse
CLAUDE_MAX_TOKENS=4096

# ===================
# Agent Configuration
# ===================

# Seuil de confiance pour escalade humaine (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.7

# Nombre maximum d'itérations par agent
MAX_AGENT_ITERATIONS=10

# Timeout par appel agent (secondes)
AGENT_TIMEOUT=60

# ===================
# ML Configuration
# ===================

# Contamination rate pour Isolation Forest (proportion d'anomalies attendues)
ANOMALY_CONTAMINATION=0.1

# Seuil p-value pour détection de drift (KS-test)
DRIFT_PVALUE_THRESHOLD=0.05

# ===================
# Data Limits
# ===================

# Taille maximale de fichier uploadé (bytes)
MAX_UPLOAD_SIZE=104857600

# Nombre maximum de lignes à analyser (0 = illimité)
MAX_ROWS_ANALYZE=100000

# ===================
# Security / Auth
# ===================

# CORS origins autorisés (format JSON array requis par pydantic-settings v2)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Activer l'authentification JWT (false en dev, true en prod)
AUTH_ENABLED=false

# Clé secrète JWT — OBLIGATOIRE si AUTH_ENABLED=true (longue chaîne aléatoire)
# JWT_SECRET_KEY=changeme-in-production-use-a-long-random-string
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=60

# ===================
# Redis / Sessions
# ===================

# URL Redis pour les sessions (fallback dict en mémoire si Redis down)
REDIS_URL=redis://localhost:6379

# Durée de vie des sessions en secondes (3600 = 1h)
SESSION_TTL=3600

# ===================
# v0.7 — LLM Quality Checks (opt-in)
# ===================

# Activer la détection sémantique via Claude LLM (désactivé par défaut)
# → Nécessite une ANTHROPIC_API_KEY valide
# → Analyse les colonnes texte (object) avec Claude pour détecter des anomalies sémantiques
# → Max 5 colonnes par analyse, 20 valeurs en sample, timeout 10s
ENABLE_LLM_CHECKS=false

# Modèle Claude utilisé pour les vérifications LLM
# Haiku = rapide et économique (recommandé), Sonnet = plus précis
LLM_CHECK_MODEL=claude-haiku-4-5-20251001
